{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Next.js: debug server-side",
      "type": "node-terminal",
      "request": "launch",
      "command": "npm run dev -- --inspect"
    },
    {
      "name": "Debug openai_extractor",
      "type": "debugpy",
      "request": "launch",
      "module": "extractors.openai_extractor",
      "cwd": "${workspaceFolder}/invoice-extractor",
      "env": {"OPENAI_API_KEY": "${env:OPENAI_API_KEY}"},
      "args": []
    }
  ]
}
